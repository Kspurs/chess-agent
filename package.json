{
  "name": "chess-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24 <26"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "build": "tsc -b && pnpm --filter @chess-agent/web build",
    "check": "tsc -b --pretty false",
    "lint": "eslint .",
    "test": "vitest run",
    "eval": "vitest run evaluations",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.62.1",
    "vitest": "^3.2.0"
  }
}
