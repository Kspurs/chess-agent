HOST=0.0.0.0
PORT=3000
APP_TOKEN=replace-with-a-long-random-value
APP_USER_ID=local-user
MODEL_PROVIDER=ollama
MODEL_NAME=qwen3:4b
MODEL_BASE_URL=http://host.docker.internal:11434
# OPENAI_API_KEY is only needed when MODEL_PROVIDER=openai
LICHESS_CLIENT_ID=example.com/chess-agent
LICHESS_REDIRECT_URI=http://localhost:8080/v1/oauth/lichess/callback
CREDENTIAL_ENCRYPTION_KEY_BASE64=replace-with-32-random-bytes-in-base64
STOCKFISH_PATH=/usr/games/stockfish
DATA_DIR=/app/data
# Optional plain Lichess puzzle CSV (CC0); imports up to 50,000 records.
# PUZZLE_DATA_PATH=/app/data/lichess_db_puzzle.csv
POSTGRES_URL=postgresql://chess:chess@postgres:5432/chess
REDIS_URL=redis://redis:6379
