{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chess Agent",
  "version": "0.1.0",
  "identifier": "com.chessagent.app",
  "build": {
    "beforeDevCommand": "pnpm --filter @chess-agent/web dev",
    "beforeBuildCommand": "pnpm --filter @chess-agent/web build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Chess Agent",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}

